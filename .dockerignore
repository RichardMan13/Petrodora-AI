# .dockerignore: Exclui arquivos irrelevantes do build context do Docker.
# Segue a Regra 3 de .gemini/rules/docker.mdc

# Git
.git
.gitignore

# Ambiente e Segredos
.env
.env.example
.venv
venv
ENV

